SECRET_KEY=change_me
DATABASE_URL=postgresql://username:password@host:5432/database_name

# -----------------------------------------------------------------------
# Import Engine — AI & OCR Configuration
# -----------------------------------------------------------------------

# --- OCR ---
ENABLE_OCR=true
# OCR_ENGINE=tesseract          # tesseract (default) or easyocr
# OCR_LANGUAGE=eng              # Tesseract language code(s), e.g. eng+hin
# OCR_DPI=200                   # PDF rasterisation DPI (higher = better quality, slower)
# OCR_CHARS_THRESHOLD=80        # Characters/page below which OCR is triggered
# LOW_DENSITY_THRESHOLD=200     # Characters/page below which low-density warning fires

# --- AI Parsing (disabled by default) ---
ENABLE_AI_IMPORT=false
# AI_PROVIDER=gemini            # gemini | openai | claude | local
# AI_FALLBACK_TO_TEXT=true      # Fall back to text extraction if AI fails

# --- Gemini ---
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_TIMEOUT=30

# --- OpenAI (future) ---
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4o-mini

# --- Anthropic Claude (future) ---
# CLAUDE_API_KEY=your-claude-api-key-here
# CLAUDE_MODEL=claude-3-haiku-20240307

# --- Local model (future, e.g. Ollama) ---
# LOCAL_MODEL_URL=http://localhost:11434/api/generate
# LOCAL_MODEL_NAME=llama3
